ES_INDEX_NAME=ebooks
ES_CLOUD_ID=
ES_CLOUD_USERNAME=
ES_CLOUD_PASSWORD=

# ── minhash-lsh-fingerprint-pipeline ──────────────────────────────────────────
# Docker image (GitHub Container Registry) — used by docker-compose.yaml
# Set to a specific tag (e.g. ghcr.io/senthilsweb/minlsh:1.0.0) to pin a version
MINLSH_IMAGE=ghcr.io/senthilsweb/minlsh:latest

# Docker port that Dagster webserver binds to
DAGSTER_PORT=3000

# Host paths bind-mounted into the container (adjust for your machine)
INPUT_DIR=./minhash-lsh-fingerprint-pipeline/data/input
OUTPUT_DIR=./minhash-lsh-fingerprint-pipeline/data/output
DAGSTER_HOME_DIR=./dagster_home

# Pipeline tuning
DOCFP_OUTPUT_ROOT=/data/output
DOCFP_SHINGLE_SIZE=5
DOCFP_MINHASH_NUM_PERM=128
DOCFP_LSH_THRESHOLD=0.5
DOCFP_DLP_SAFE_MODE=true
DOCFP_OCR_ENABLED=false
DOCFP_LOG_LEVEL=INFO

# Tika (leave empty to let Tika auto-download at first run)
TIKA_SERVER_JAR=
JAVA_OPTS=-Xmx512m
